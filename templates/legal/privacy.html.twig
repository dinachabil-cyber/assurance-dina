{% extends 'base.html.twig' %}

{% block title %}Politique de confidentialité{% endblock %}

{% block body %}

<section class="py-20 bg-white">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">

        <h1 class="text-4xl font-extrabold text-slate-900 mb-10">
            Politique de confidentialité
        </h1>

        <div class="space-y-10 text-slate-700 leading-relaxed">

            <div>
                <h2 class="text-2xl font-bold text-slate-900 mb-4">1. Responsable du traitement</h2>
                <p>
                    Le responsable du traitement des données personnelles est :
                </p>
                <p class="mt-2">
                    <strong>Aksam Assurances</strong><br>
                    Email : contact@aksam-assurances.fr
                </p>
            </div>

           

            <div>
                <h2 class="text-2xl font-bold text-slate-900 mb-4">3. Finalités du traitement</h2>
                <p>
                    Les données collectées sont utilisées pour :
                </p>
                <ul class="list-disc pl-6 mt-2 space-y-1">
                    <li>Vous recontacter suite à votre demande de devis</li>
                    <li>Vous transmettre des informations sur nos offres d'assurance</li>
                </ul>
            </div>

            <div>
                <h2 class="text-2xl font-bold text-slate-900 mb-4">4. Base légale du traitement</h2>
                <p>
                    Le traitement est fondé sur votre consentement, que vous donnez en soumettant
                    volontairement le formulaire de demande de devis.
                </p>
            </div>

            <div>
                <h2 class="text-2xl font-bold text-slate-900 mb-4">5. Durée de conservation</h2>
                <p>
                    Vos données sont conservées pendant une durée maximale de 3 ans à compter
                    de votre dernière interaction avec nos services.
                </p>
            </div>

            <div>
                <h2 class="text-2xl font-bold text-slate-900 mb-4">6. Vos droits</h2>
                <p>
                    Vous disposez d'un droit d'accès, de rectification, d'effacement et
                    d'opposition à vos données personnelles. Pour exercer ces droits,
                    contactez-nous à l'adresse : contact@aksam-assurances.fr
                </p>
            </div>

            <div>
                <h2 class="text-2xl font-bold text-slate-900 mb-4">7. Cookies</h2>
                <p>
                    Ce site n'utilise pas de cookies à des fins de tracking ou publicitaires.
                    Seuls les cookies strictement nécessaires au fonctionnement du site peuvent être utilisés.
                </p>
            </div>

        </div>

    </div>
</section>

{% endblock %}
