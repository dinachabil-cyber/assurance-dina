{% extends 'base.html.twig' %}

{% block title %}Merci{% endblock %}

{% block body %}

<section class="bg-gradient-to-br from-blue-50 to-white py-20">
    <div class="max-w-2xl mx-auto px-4 sm:px-6 lg:px-8 text-center">

        <div class="bg-white rounded-2xl shadow-xl p-12">

            <div class="w-16 h-16 mx-auto bg-green-100 rounded-full flex items-center justify-center mb-6">
                <span class="text-3xl">✔</span>
            </div>

            <h1 class="text-3xl font-extrabold text-slate-900 mb-4">
                Merci pour votre demande
            </h1>

            <p class="text-lg text-slate-600 mb-8">
                Votre demande a bien été envoyée. Un de nos conseillers vous
                recontactera dans les plus brefs délais.
            </p>

            <a
                href="{{ path('app_home') }}"
                class="inline-block rounded-lg bg-blue-600 px-8 py-3 text-white font-semibold hover:bg-blue-700"
            >
                Retour à l'accueil
            </a>

        </div>

    </div>
</section>

{% endblock %}
