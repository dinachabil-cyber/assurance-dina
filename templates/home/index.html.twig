{% extends 'base.html.twig' %}

{% block title %}Accueil{% endblock %}

{% block body %}

<section class="bg-gradient-to-br from-blue-50 to-white py-20">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">

        <div class="grid lg:grid-cols-2 gap-12 items-center">

            <!-- Left -->
            <div>
                <span class="inline-flex items-center rounded-full bg-blue-100 px-4 py-2 text-sm font-medium text-blue-700 mb-6">
                    Courtier en assurances
                </span>

                <h1 class="text-5xl font-extrabold text-slate-900 leading-tight mb-6">
                    Obtenez votre devis d'assurance professionnelle
                </h1>

                <p class="text-lg text-slate-600 leading-8 mb-8">
                    Comparez les meilleures offres d'assurance en quelques minutes.
                    Notre équipe vous accompagne gratuitement afin de trouver la
                    solution adaptée à votre activité.
                </p>

                <div class="flex flex-wrap gap-4">
                    <div class="flex items-center gap-2">
                        <span class="text-green-600">✔</span>
                        <span>Devis gratuit</span>
                    </div>

                    <div class="flex items-center gap-2">
                        <span class="text-green-600">✔</span>
                        <span>Réponse rapide</span>
                    </div>

                    <div class="flex items-center gap-2">
                        <span class="text-green-600">✔</span>
                        <span>Sans engagement</span>
                    </div>
                </div>
            </div>

            <!-- Right -->
            <div class="bg-white rounded-2xl shadow-xl p-8">

                <h2 class="text-2xl font-bold text-center mb-6">
                    Demander un devis
                </h2>

                {{ form_start(form) }}

                <div class="space-y-4">
                    {{ form_row(form.name) }}

                    {{ form_row(form.prenom) }}

                    {{ form_row(form.email) }}

                    {{ form_row(form.telephone) }}
                </div>

                <button
                    type="submit"
                    class="mt-6 w-full rounded-lg bg-blue-600 py-3 text-white font-semibold hover:bg-blue-700 transition-colors duration-200"
                >
                    Obtenir mon devis
                </button>

                {{ form_end(form) }}

            </div>

        </div>

    </div>
</section>

<section class="py-20 bg-white">
    <div class="max-w-7xl mx-auto px-4">

        <h2 class="text-3xl font-bold text-center mb-12">
            Pourquoi choisir AKSAM ASSURANCES ?
        </h2>

        <div class="grid md:grid-cols-3 gap-8">

            <div class="bg-gray-50 rounded-xl p-8 shadow-sm">
                <h3 class="font-bold text-xl mb-4">Expertise</h3>
                <p class="text-gray-600">
                    Des conseillers spécialisés dans les assurances professionnelles.
                </p>
            </div>

            <div class="bg-gray-50 rounded-xl p-8 shadow-sm">
                <h3 class="font-bold text-xl mb-4">Rapidité</h3>
                <p class="text-gray-600">
                    Recevez une proposition rapidement après votre demande.
                </p>
            </div>

            <div class="bg-gray-50 rounded-xl p-8 shadow-sm">
                <h3 class="font-bold text-xl mb-4">Accompagnement</h3>
                <p class="text-gray-600">
                    Un interlocuteur unique pour répondre à toutes vos questions.
                </p>
            </div>

        </div>

    </div>
</section>

{% endblock %}